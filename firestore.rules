rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if true;
      // TODO: Replace YOUR_ADMIN_UID with your Firebase Auth UID
      allow create, delete: if request.auth != null && request.auth.uid == 'YOUR_ADMIN_UID';
      allow update: if (request.auth != null && request.auth.uid == 'YOUR_ADMIN_UID')
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes']);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.resource.data.nickname is string
                      && request.resource.data.content is string
                      && request.resource.data.nickname.size() >= 1
                      && request.resource.data.nickname.size() <= 20
                      && request.resource.data.content.size() >= 1
                      && request.resource.data.content.size() <= 500;
      }
    }
    match /portfolio/{docId} {
      allow read: if true;
      // TODO: Replace YOUR_ADMIN_UID with your Firebase Auth UID
      allow write: if request.auth != null && request.auth.uid == 'YOUR_ADMIN_UID';
    }
  }
}
