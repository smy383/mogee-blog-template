# ─── Firebase Configuration ──────────────────────────────────────
# Get these from Firebase Console > Project Settings > General > Your apps > Web app
REACT_APP_FIREBASE_API_KEY=your-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# ─── Site Configuration ─────────────────────────────────────────
REACT_APP_SITE_NAME=My Blog
REACT_APP_SITE_URL=https://your-blog.web.app
REACT_APP_SITE_DESCRIPTION=My personal developer blog
REACT_APP_SITE_TAGLINE=Building amazing things with code

# ─── Personal Info ───────────────────────────────────────────────
REACT_APP_GITHUB_URL=https://github.com/your-username
REACT_APP_CONTACT_EMAIL=your-email@example.com
